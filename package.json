{
  "name": "codex-poker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first Texas Hold'em table for playing poker with Codex in the preview.",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "server": "tsx src/server/index.ts",
    "game:codex": "tsx src/cli/game-codex.ts",
    "game:state": "tsx src/cli/game-state.ts",
    "game:banter": "tsx src/cli/game-banter.ts",
    "game:turn": "tsx src/cli/game-turn.ts",
    "game:play": "tsx src/cli/game-play.ts",
    "game:act": "tsx src/cli/game-act.ts",
    "game:next": "tsx src/cli/game-next.ts",
    "game:review": "tsx src/cli/game-review.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.2.0",
    "fastify": "^5.4.0",
    "lucide-react": "^0.468.0",
    "poker-ts": "1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
